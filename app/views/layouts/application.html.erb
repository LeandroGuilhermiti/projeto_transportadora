<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Projeto Transportadora" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Projeto Transportadora">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <% unless devise_controller? %>
      <nav class="navbar">
      <div class="navbar-content">
        <%= link_to 'Rotagily', root_path, class: 'brand-logo' %>
        <div class="nav-links">
          <% if user_signed_in? %>
            <span class="user-greeting">Olá, <%= current_user.nome %> (<%= current_user.cargo.capitalize %>)</span>
            <%= link_to 'Pacotes', packages_path, class: 'nav-item' %>
            <% if current_user.admin? %>
              <%= link_to 'Veículos', vehicles_path, class: 'nav-item' %>
            <% end %>
            <%= button_to 'Sair', destroy_user_session_path, method: :delete, class: 'btn btn-logout' %>
          <% else %>
            <button class="btn btn-login" onclick="openModal('modal-entrar')">Entrar</button>
            <button class="btn btn-primary" style="margin-left: 10px;" onclick="openModal('modal-criar-conta')">Criar Conta</button>
          <% end %>
        </div>
      </div>
    </nav>
    <% end %>

    <main class="main-content" style="<%= 'padding: 0; margin: 0;' if devise_controller? %>">
      <%= yield %>
    </main>

    <!-- Overlay e JS para fechar os modais -->
    <div id="modal-overlay" class="modal-overlay" onclick="closeAllModals()"></div>

    <!-- Modal Entrar -->
    <div id="modal-entrar" class="side-modal">
      <div class="modal-header">
        <h3>O que você deseja fazer?</h3>
        <button class="close-btn" onclick="closeAllModals()">&times;</button>
      </div>
      
      <%= link_to new_user_session_path, class: 'modal-card' do %>
        <div class="modal-card-content">
          <h4>Login para envios</h4>
          <span class="modal-card-btn">Entrar</span>
        </div>
        <div style="font-size: 2rem;">📦</div>
      <% end %>

      <%= link_to new_user_session_path, class: 'modal-card' do %>
        <div class="modal-card-content">
          <h4>Login para motoristas</h4>
          <span class="modal-card-btn">Entrar</span>
        </div>
        <div style="font-size: 2rem;">🚚</div>
      <% end %>
    </div>

    <!-- Modal Criar Conta -->
    <div id="modal-criar-conta" class="side-modal">
      <div class="modal-header">
        <h3>O que você deseja fazer?</h3>
        <button class="close-btn" onclick="closeAllModals()">&times;</button>
      </div>
      
      <%= link_to new_user_registration_path(cargo: 'cliente'), class: 'modal-card' do %>
        <div class="modal-card-content">
          <h4>Quero enviar pacotes</h4>
          <span class="modal-card-btn">Criar Conta</span>
        </div>
        <div style="font-size: 2rem;">📦</div>
      <% end %>

      <%= link_to new_user_registration_path(cargo: 'motorista'), class: 'modal-card' do %>
        <div class="modal-card-content">
          <h4>Quero ser entregador</h4>
          <span class="modal-card-btn">Criar Conta</span>
        </div>
        <div style="font-size: 2rem;">🏍️</div>
      <% end %>
    </div>

    <script>
      function openModal(id) {
        closeAllModals();
        document.getElementById(id).classList.add('active');
        document.getElementById('modal-overlay').classList.add('active');
      }

      function closeAllModals() {
        document.querySelectorAll('.side-modal.active, .modal-overlay.active').forEach(function(el) {
          el.classList.remove('active');
        });
      }
    </script>
  </body>
</html>
