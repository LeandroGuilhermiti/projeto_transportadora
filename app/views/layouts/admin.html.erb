<!DOCTYPE html>
<html>
  <head>
    <title>Rotagily - Admin Dashboard</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "admin", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "admin_dashboard", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "admin_entregas", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "admin_motoristas", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "admin_nova_entrega", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "package_details", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "vehicles", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "settings", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <script>
      function setTheme(theme) {
        if (theme === 'dark') {
          document.documentElement.classList.add('dark-mode');
          localStorage.setItem('theme', 'dark');
          updateThemeButtons('dark');
        } else {
          document.documentElement.classList.remove('dark-mode');
          localStorage.setItem('theme', 'light');
          updateThemeButtons('light');
        }
      }

      function updateThemeButtons(theme) {
        const btnLight = document.getElementById('btn-theme-light');
        const btnDark = document.getElementById('btn-theme-dark');
        if (btnLight && btnDark) {
          if (theme === 'dark') {
            btnDark.classList.add('active');
            btnLight.classList.remove('active');
          } else {
            btnLight.classList.add('active');
            btnDark.classList.remove('active');
          }
        }
      }

      // Evita o flash de tela branca antes do carregamento completo do DOM
      const initTheme = localStorage.getItem('theme') || 'light';
      if (initTheme === 'dark') {
        document.documentElement.classList.add('dark-mode');
      }

      // Atualiza os botões visuais quando os elementos existem
      document.addEventListener("turbo:load", function() {
        updateThemeButtons(localStorage.getItem('theme') || 'light');
      });
      document.addEventListener("DOMContentLoaded", function() {
        updateThemeButtons(localStorage.getItem('theme') || 'light');
      });
    </script>
  </head>

  <body class="admin-body">
    <div class="admin-wrapper">
      <aside class="admin-sidebar">
        <div class="sidebar-brand">
          <%= link_to admin_dashboard_path, style: "text-decoration: none; color: inherit;" do %>
            <h3>Rotagily</h3>
            <p>LOGÍSTICA INTELIGENTE</p>
          <% end %>
        </div>
        <nav class="sidebar-nav">
          <a href="<%= admin_dashboard_path %>" class="nav-item <%= current_page?(admin_dashboard_path) ? 'active' : '' %>">Dashboard</a>
          <a href="<%= admin_entregas_path %>" class="nav-item <%= current_page?(admin_entregas_path) ? 'active' : '' %>">Entregas</a>
          <a href="<%= admin_packages_path %>" class="nav-item <%= current_page?(admin_packages_path) ? 'active' : '' %>">Pacotes</a>
          <a href="<%= vehicles_path %>" class="nav-item <%= current_page?(vehicles_path) ? 'active' : '' %>">Veículos</a>
          <a href="<%= admin_drivers_path %>" class="nav-item <%= current_page?(admin_drivers_path) ? 'active' : '' %>">Motoristas</a>
          <a href="<%= admin_settings_path %>" class="nav-item <%= current_page?(admin_settings_path) ? 'active' : '' %>">Configurações</a>
        </nav>
        <div class="sidebar-footer">
          <%= link_to "+ Novo Pacote", new_admin_package_path, class: "btn-nova-entrega", data: { turbo: false } %>
        </div>
      </aside>

      <div class="admin-main-content">
        <header class="admin-topbar">
          <div class="search-box">
             <input type="text" placeholder="Pesquisar entregas, motoristas ou placas...">
          </div>
          <div class="user-profile">
            <div class="profile-text">
              <strong><%= current_user&.nome || "Admin" %></strong>
              <span>Logistics Manager</span>
            </div>
            <%= button_to "Sair", destroy_user_session_path, method: :delete, class: "btn btn-sm btn-outline-danger", style: "margin-left: 10px;" %>
          </div>
        </header>

        <main class="admin-yield">
          <%= yield %>
        </main>
      </div>
    </div>
  </body>
</html>
