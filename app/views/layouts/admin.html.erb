<!DOCTYPE html>
<html>
  <head>
    <title>Rotagily - Admin Dashboard</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "admin", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="admin-body">
    <div class="admin-wrapper">
      <aside class="admin-sidebar">
        <div class="sidebar-brand">
          <%= link_to admin_dashboard_path, style: "text-decoration: none; color: inherit;" do %>
            <h3>Rotagily</h3>
            <p>LOGÍSTICA INTELIGENTE</p>
          <% end %>
        </div>
        <nav class="sidebar-nav">
          <a href="<%= admin_dashboard_path %>" class="nav-item <%= current_page?(admin_dashboard_path) ? 'active' : '' %>">Dashboard</a>
          <a href="<%= admin_packages_path %>" class="nav-item <%= current_page?(admin_packages_path) ? 'active' : '' %>">Entregas</a>
          <a href="<%= vehicles_path %>" class="nav-item <%= current_page?(vehicles_path) ? 'active' : '' %>">Veículos</a>
          <a href="<%= admin_drivers_path %>" class="nav-item <%= current_page?(admin_drivers_path) ? 'active' : '' %>">Motoristas</a>
        </nav>
        <div class="sidebar-footer">
          <%= link_to "+ Nova Entrega", new_package_path, class: "btn-nova-entrega", data: { turbo: false } %>
        </div>
      </aside>

      <div class="admin-main-content">
        <header class="admin-topbar">
          <div class="search-box">
             <input type="text" placeholder="Pesquisar entregas, motoristas ou placas...">
          </div>
          <div class="user-profile">
            <div class="profile-text">
              <strong><%= current_user&.nome || "Admin" %></strong>
              <span>Logistics Manager</span>
            </div>
            <%= button_to "Sair", destroy_user_session_path, method: :delete, class: "btn btn-sm btn-outline-danger", style: "margin-left: 10px;" %>
          </div>
        </header>

        <main class="admin-yield">
          <%= yield %>
        </main>
      </div>
    </div>
  </body>
</html>
