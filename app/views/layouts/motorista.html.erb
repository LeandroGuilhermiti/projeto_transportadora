<!DOCTYPE html>
<html>
  <head>
    <title>Rotagily - Área do Motorista</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "admin", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "admin_rotas", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <script>
      function setTheme(theme) {
        if (theme === 'dark') {
          document.documentElement.classList.add('dark-mode');
          localStorage.setItem('theme', 'dark');
          updateThemeButtons('dark');
        } else {
          document.documentElement.classList.remove('dark-mode');
          localStorage.setItem('theme', 'light');
          updateThemeButtons('light');
        }
      }

      function updateThemeButtons(theme) {
        const btnLight = document.getElementById('btn-theme-light');
        const btnDark = document.getElementById('btn-theme-dark');
        if (btnLight && btnDark) {
          if (theme === 'dark') {
            btnDark.classList.add('active');
            btnLight.classList.remove('active');
          } else {
            btnLight.classList.add('active');
            btnDark.classList.remove('active');
          }
        }
      }

      // Evita o flash de tela branca antes do carregamento completo do DOM
      const initTheme = localStorage.getItem('theme') || 'light';
      if (initTheme === 'dark') {
        document.documentElement.classList.add('dark-mode');
      }

      // Atualiza os botões visuais quando os elementos existem
      document.addEventListener("turbo:load", function() {
        updateThemeButtons(localStorage.getItem('theme') || 'light');
      });
      document.addEventListener("DOMContentLoaded", function() {
        updateThemeButtons(localStorage.getItem('theme') || 'light');
      });
    </script>
  </head>

  <body class="admin-body">
    <div class="admin-wrapper">
      <aside class="admin-sidebar">
        <div class="sidebar-brand">
          <div style="text-decoration: none; color: inherit;">
            <h3>Rotagily</h3>
            <p>CONDUÇÃO LOGÍSTICA</p>
          </div>
        </div>
        <nav class="sidebar-nav">
          <a href="<%= motorista_rotas_path %>" class="nav-item <%= current_page?(motorista_rotas_path) ? 'active' : '' %>">Minhas Rotas</a>
        </nav>
        <div class="sidebar-footer" style="padding: 20px; text-align: center; color: var(--text-muted); font-size: 0.75rem;">
          Portal do Condutor v1.0
        </div>
      </aside>

      <div class="admin-main-content">
        <header class="admin-topbar">
          <div class="search-box">
             <!-- Vazio para motorista ou informativo -->
             <span style="font-size: 0.85rem; color: var(--text-muted);">Painel de Controle da Viagem</span>
          </div>
          <div class="user-profile">
            <div class="profile-text">
              <strong><%= current_user&.nome || "Motorista" %></strong>
              <span>Condutor Profissional</span>
            </div>
            <%= button_to "Sair", destroy_user_session_path, method: :delete, class: "btn btn-sm btn-outline-danger", style: "margin-left: 10px;" %>
          </div>
        </header>

        <main class="admin-yield">
          <%= yield %>
        </main>
      </div>
    </div>
  </body>
</html>
