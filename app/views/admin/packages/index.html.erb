<div class="deliveries-wrapper">
  <!-- Cabeçalho -->
  <div class="page-header-row">
    <div>
      <% if @motorista_filtro %>
        <div style="margin-bottom: 6px;">
          <%= link_to "← Voltar para Motoristas", admin_drivers_path, style: "font-size: 0.85rem; color: var(--accent-blue); text-decoration: none;", data: { turbo: false } %>
        </div>
        <h1 class="page-title">Entregas de <%= @motorista_filtro.nome %></h1>
        <p class="page-subtitle">Pacotes atribuídos a este motorista.</p>
      <% else %>
        <h1 class="page-title">Pacotes</h1>
        <p class="page-subtitle">Cadastro e dados físicos dos pacotes registrados no sistema.</p>
      <% end %>
    </div>
    <%= link_to "+ Novo Pacote", new_admin_package_path, class: "btn-primary-blue", data: { turbo: false } %>
  </div>

  <!-- Tabela de Pacotes -->
  <div class="table-container">
    <table class="delivery-table">
      <thead>
        <tr>
          <th>CÓDIGO DE RASTREIO</th>
          <th>DESTINATÁRIO</th>
          <th>ENDEREÇO</th>
          <th>PESO</th>
          <th>DIMENSÕES</th>
          <th>CADASTRADO EM</th>
          <th>AÇÕES</th>
        </tr>
      </thead>
      <tbody>
        <% @packages.each do |package| %>
          <tr>
            <td><strong style="color: var(--accent-blue); font-family: monospace;">#<%= package.codigo_rastreio || '—' %></strong></td>
            <td><strong><%= package.destinatario %></strong></td>
            <td style="color: var(--text-muted); font-size: 0.8rem;"><%= package.endereco %></td>
            <td><%= package.peso.present? ? "#{package.peso} kg" : '—' %></td>
            <td><%= package.dimensoes.present? ? package.dimensoes : '—' %></td>
            <td style="color: var(--text-muted);"><%= package.created_at.strftime("%d/%m/%Y") %></td>
            <td class="table-actions">
              <%= link_to "👁", package, class: "action-icon", title: "Ver", data: { turbo: false } %>
              <%= link_to "✎", edit_package_path(package), class: "action-icon", title: "Editar", data: { turbo: false } %>
              <%= button_to "✕", package, method: :delete, class: "action-icon red", title: "Apagar" %>
            </td>
          </tr>
        <% end %>

        <% if @packages.empty? %>
          <tr>
            <td colspan="7" style="text-align: center; padding: 40px; color: var(--text-muted);">
              Nenhum pacote cadastrado ainda.
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <div class="table-footer">
      <p>Mostrando <strong><%= @packages.count %></strong> pacote(s)</p>
    </div>
  </div>
</div>
