<div class="nova-entrega-wrapper">

  <!-- Cabeçalho -->
  <div class="ne-page-header">
    <div>
      <h1 class="ne-title">Adicionar Motorista</h1>
      <p class="ne-subtitle">Cadastre um novo motorista na equipe de logística.</p>
    </div>

  </div>

  <%= form_with(model: [:admin, @motorista], url: admin_drivers_path, method: :post, data: { turbo: false }) do |form| %>

    <% if @motorista.errors.any? %>
      <div class="ne-errors">
        <strong><%= @motorista.errors.count %> erro(s) impediram o salvamento:</strong>
        <ul>
          <% @motorista.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <!-- Card: Informações Pessoais -->
    <div class="ne-card" style="max-width: 720px;">
      <div class="ne-card-header">
        <div class="ne-card-icon" style="background: #dcfce7;">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
               stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="8" r="5"/><path d="M20 21a8 8 0 1 0-16 0"/>
          </svg>
        </div>
        <h3 class="ne-card-title">Informações do Motorista</h3>
      </div>

      <!-- Nome completo -->
      <div class="ne-field-full">
        <label class="ne-label">Nome Completo</label>
        <%= form.text_field :nome, class: "ne-input", placeholder: "Ex: João Silva", required: true %>
      </div>

      <!-- E-mail -->
      <div class="ne-field-full">
        <label class="ne-label">E-mail de Acesso</label>
        <%= form.email_field :email, class: "ne-input ne-font-mono", placeholder: "email@exemplo.com", required: true %>
      </div>

      <!-- Região de Atuação -->
      <div class="ne-field-full">
        <label class="ne-label">Região de Atuação (Capital)</label>
        <%= form.select :regiao_atuacao,
            Package::CAPITAL_COORDINATES.keys.sort,
            { prompt: "Selecione a capital de atuação" },
            class: "ne-input ne-select", required: true %>
      </div>
    </div>

    <!-- Card: Credenciais de Acesso -->
    <div class="ne-card" style="max-width: 720px; margin-top: 20px;">
      <div class="ne-card-header">
        <div class="ne-card-icon" style="background: #ede9fe;">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
               stroke="#7c3aed" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="18" height="11" x="3" y="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
        </div>
        <h3 class="ne-card-title">Credenciais de Acesso ao Sistema</h3>
      </div>

      <!-- Senha -->
      <div class="ne-row-2">
        <div>
          <label class="ne-label">Senha</label>
          <%= form.password_field :password, class: "ne-input",
              placeholder: "Mínimo 6 caracteres", required: true,
              autocomplete: "new-password" %>
        </div>
        <div>
          <label class="ne-label">Confirmar Senha</label>
          <%= form.password_field :password_confirmation, class: "ne-input",
              placeholder: "Repita a senha", required: true,
              autocomplete: "new-password" %>
        </div>
      </div>

      <div style="margin-top: 10px; padding: 12px 16px; background: #f0f9ff; border: 1px solid #bae6fd;
                  border-radius: 8px; font-size: 0.82rem; color: #0369a1; display: flex; gap: 8px; align-items: flex-start;">
        <span>ℹ️</span>
        <span>O motorista utilizará este e-mail e senha para acessar o aplicativo e visualizar as entregas atribuídas a ele.</span>
      </div>
    </div>

    <!-- Rodapé de Ação -->
    <div class="ne-footer" style="max-width: 720px; margin-top: 24px; display: flex; gap: 12px; align-items: center;">
      <%= form.submit "Cadastrar Motorista", class: "btn-ne-submit" %>
      <%= link_to "Cancelar", admin_drivers_path,
          class: "btn-ne-cancelar", data: { turbo: false },
          style: "padding: 12px 24px;" %>
    </div>

  <% end %>
</div>
