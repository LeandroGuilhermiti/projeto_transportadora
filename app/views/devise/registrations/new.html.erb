<div class="split-screen">
  <div class="split-left">
    <div class="split-left-content">
      <div style="font-size: 5rem; margin-bottom: 20px;">📦</div>
      <div class="auth-hero-text">
        <span style="color: var(--color-gold);">Junte-se a nós</span> e faça<br> envios seguros e<br> super rápidos.
      </div>
      <p style="margin-top: 20px; font-size: 1.1rem; opacity: 0.9;">Crie sua conta na Rotagily para começar!</p>
    </div>
  </div>

  <div class="split-right">
    <div class="auth-form-container">
      <h2>Crie sua conta (<%= params[:cargo] == 'motorista' ? 'Entregador' : 'Cliente' %>)</h2>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <%= f.hidden_field :cargo, value: params[:cargo] || 'cliente' %>

        <div class="field">
          <%= f.text_field :nome, autofocus: true, autocomplete: "name", placeholder: "Nome Completo", class: "auth-input", required: true %>
        </div>

        <div class="field">
          <%= f.email_field :email, autocomplete: "email", placeholder: "E-mail", class: "auth-input" %>
        </div>

        <div class="field">
          <% if @minimum_password_length %>
          <em style="color: #666; font-size: 0.8rem; display: block; text-align: left; margin-bottom: 5px;">(<%= @minimum_password_length %> caracteres no mínimo)</em>
          <% end %>
          <%= f.password_field :password, autocomplete: "new-password", placeholder: "Senha", class: "auth-input" %>
        </div>

        <div class="field">
          <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "Confirme a Senha", class: "auth-input" %>
        </div>

        <div class="actions">
          <%= f.submit "Criar Conta", class: "auth-btn" %>
        </div>
      <% end %>

      <div class="social-login-sep">
        <span>Ou escolha</span>
      </div>

      <button class="social-btn">
        <svg class="icon-svg" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        Continuar com Google
      </button>

      <button class="social-btn">
        <svg class="icon-svg" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.15 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.62 1.54-1.47 3.01-2.53 4.08zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z" fill="#000000"/>
        </svg>
        Continuar com Apple
      </button>

      <div class="auth-links" style="margin-top: 30px;">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>
