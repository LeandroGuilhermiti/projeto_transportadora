<%
  status_clean = (@package.status || "Pendente").downcase
  status_class = "default"
  status_class = "pendente" if status_clean.include?("pendente") || status_clean.include?("criado")
  status_class = "rota" if status_clean.include?("rota") || status_clean.include?("trânsito")
  status_class = "entregue" if status_clean.include?("entregue")

  # Lógica simples de timeline
  event_created = @package.created_at
  event_collected = event_created + 2.hours
  event_routing = event_created + 4.hours
  event_delivered = @package.updated_at

  # Quais passos estão ativos?
  step_collected = (status_class == "rota" || status_class == "entregue")
  step_routing = (status_class == "rota" || status_class == "entregue")
  step_delivered = (status_class == "entregue")
%>

<div class="pkg-wrapper">
  
  <!-- Header Section -->
  <div class="pkg-header">
    <div class="pkg-header-left">
      <% back_path = current_user&.admin? ? admin_packages_path : packages_path %>
      <%= link_to back_path, class: "pkg-back-link" do %>
        &larr; Voltar para Entregas
      <% end %>
      <h2 class="pkg-title">Detalhes da Entrega</h2>
      <p class="pkg-id">#<%= @package.codigo_rastreio %></p>
    </div>
    <div class="pkg-actions">
      <button onclick="window.print()" class="btn-pkg btn-pkg-outline">
        Imprimir Etiqueta
      </button>
      <% if current_user&.admin? %>
        <%= link_to edit_package_path(@package), class: "btn-pkg btn-pkg-primary" do %>
          Editar Pedido
        <% end %>
      <% end %>
    </div>
  </div>

  <!-- Bento Grid Layout -->
  <div class="bento-grid">
    
    <!-- Main Details Col -->
    <div class="bento-col-main">
      
      <!-- Row 1: Status & Important Info -->
      <div class="bento-row-2">
        <div class="card-tonal">
          <div class="status-container">
            <div>
              <span class="card-label">Status Atual</span>
              <div class="status-indicator">
                <div class="status-dot <%= status_class %>"></div>
                <h3 class="status-text"><%= @package.status || "Pendente" %></h3>
              </div>
              <p style="color: var(--text-muted); font-size: 0.9rem; margin-top: 10px;">
                Última atualização: <%= @package.updated_at.strftime("%d/%m/%Y às %H:%M") %>
              </p>
            </div>
            <div class="status-footer">
              <p>O acompanhamento é atualizado a cada evento.</p>
            </div>
          </div>
        </div>

        <div class="card-tonal">
          <span class="card-label">Dados do Pacote</span>
          <div class="pkg-data-list">
            <div class="pkg-data-item">
              <span class="data-key">Código Rastreio</span>
              <span class="data-value"><%= @package.codigo_rastreio %></span>
            </div>
            <div class="pkg-data-item">
              <span class="data-key">Peso Estimado</span>
              <span class="data-value"><%= @package.peso.present? ? "#{@package.peso} kg" : "Não especificado" %></span>
            </div>
            <div class="pkg-data-item">
              <span class="data-key">Dimensões</span>
              <span class="data-value"><%= @package.dimensoes.present? ? @package.dimensoes : "Não especificado" %></span>
            </div>
          </div>
        </div>
      </div>

      <!-- Row 2: Origin & Destination -->
      <div class="bento-row-2">
        <div class="card-surface">
          <div class="loc-header">
            <div class="loc-icon-wrapper origin">W</div>
            <div>
              <span class="card-label">Coleta (Origem)</span>
              <h4 class="loc-title">Central Operacional</h4>
            </div>
          </div>
          <p class="loc-address">
            Ponto de origem padrão<br/>
            (Verificar detalhes na central)
          </p>
          <div class="loc-contact">
            Rotagily Logistics Intelligence
          </div>
        </div>

        <div class="card-accent">
          <div class="loc-header">
            <div class="loc-icon-wrapper dest">D</div>
            <div>
              <span class="card-label">Entrega (Destino)</span>
              <h4 class="loc-title"><%= @package.destinatario %></h4>
            </div>
          </div>
          <p class="loc-address">
            <%= @package.endereco %>
          </p>
          <div class="loc-contact">
            <%= @package.regiao || "Região padrão" %>
          </div>
        </div>
      </div>

      <!-- Row 3: Driver & Vehicle -->
      <div class="card-tonal">
        <div class="driver-header">
          <span class="card-label">Motorista Responsável</span>
          <% if @package.driver.present? %>
            <span class="driver-badge">ATRIBUÍDO</span>
          <% else %>
            <span class="driver-badge" style="background-color: #fef08a; color: #854d0e;">NÃO ATRIBUÍDO</span>
          <% end %>
        </div>
        
        <div class="driver-profile">
          <% if @package.driver.present? %>
            <img class="driver-avatar" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCms578D6DyXZbpowQb-dTxKtGzlHfXlTR-IWMUJK-iRbqBamQzFJwvtLfK_F9bphCeImfEaQBepQVjskfuQE3STnzb8sM5PNEF0BUeHjel8fDnf15cljkvofHE34nyZCMsYwpGXypsfPfNQITP5bxtd3qEtRETJYXLZHFVYM_slqlyGHFOOdUTgztP0_mqJdv_1p9Cdw4YaiJ4HEKHEf_8kKGUesFJ0Vg58taJVpoCHdY1rdlHMiXBlmJ1fm9WL1mKrSAoOuU1BKQ" alt="Motorista">
            <div class="driver-info-grid">
              <div class="driver-info-item">
                <p class="lbl">Nome Completo</p>
                <p class="val"><%= @package.driver.nome %></p>
              </div>
              <div class="driver-info-item">
                <p class="lbl">E-mail</p>
                <p class="val" style="word-break: break-all; font-size: 0.9rem;"><%= @package.driver.email %></p>
              </div>
              <div class="driver-info-item">
                <p class="lbl">Região</p>
                <p class="val"><%= @package.driver.regiao_atuacao || "Geral" %></p>
              </div>
            </div>
          <% else %>
            <div class="driver-info-grid" style="flex: 1;">
              <div style="grid-column: span 3; text-align: center; padding: 20px;">
                <p style="margin: 0 0 15px 0; color: var(--text-muted);">Nenhum motorista foi atribuído a esta entrega ainda.</p>
                <% if current_user&.admin? %>
                  <%= link_to "Atribuir Motorista", edit_package_path(@package), class: "btn-pkg btn-pkg-primary", style: "display: inline-block;" %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
      
    </div>

    <!-- Right Timeline/Map Col -->
    <div class="bento-col-side">
      
      <!-- Leaflet Map Container -->
      <div id="map"></div>

      <!-- Painel de Simulação -->
      <div class="card-tonal simulation-card">
        <h3 style="margin-top: 0; color: var(--color-blue); font-size: 1.2rem;">🎮 Painel de Simulação</h3>
        <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 15px;">
          Simule a rota de entrega do veículo em tempo real para os avaliadores.
        </p>
        
        <div class="simulation-controls" style="display: flex; gap: 10px; margin-bottom: 15px;">
          <button id="btn-start-sim" class="btn-pkg btn-pkg-primary" style="flex: 1;" disabled>
            Iniciar Rota
          </button>
          <%= button_to "Resetar", reset_tracking_package_path(@package), method: :post, class: "btn-pkg btn-pkg-outline", style: "flex: 1; text-align: center; display: inline-block;" %>
        </div>
        
        <div class="simulation-speed" style="display: flex; align-items: center; justify-content: space-between; font-size: 0.85rem; margin-bottom: 10px;">
          <span style="color: var(--text-muted);">Velocidade:</span>
          <select id="sim-speed" style="background: var(--bg-card); color: var(--text-main); border: 1px solid var(--border-color); padding: 6px 12px; border-radius: 6px; font-weight: 600;">
            <option value="400">Rápida (Apresentação)</option>
            <option value="1500">Normal (Realista)</option>
          </select>
        </div>
        
        <div id="sim-status" style="font-size: 0.85rem; color: var(--text-muted); text-align: center; border-top: 1px dashed var(--border-color); padding-top: 10px; margin-top: 10px;">
          Carregando rota...
        </div>
      </div>

      <!-- Timeline Section -->
      <div class="card-tonal" style="flex: 1; display: flex; flex-direction: column;">
        <h3 class="timeline-title">Histórico de Eventos</h3>
        
        <div class="timeline-container" id="timeline-container">
          <div class="timeline-track"></div>

          <% events = @package.tracking_events.order(created_at: :desc) %>
          <% if events.any? %>
            <% events.each do |event| %>
              <div class="timeline-item active">
                <div class="timeline-icon">✓</div>
                <div class="timeline-content">
                  <div class="timeline-header">
                    <p class="timeline-step"><%= event.status %></p>
                    <span class="timeline-time"><%= event.created_at.strftime("%H:%M") %></span>
                  </div>
                  <p class="timeline-desc">
                    <%= event.descricao %>
                    <% if event.localizacao.present? %>
                      <br/><small style="color: var(--color-blue);">📍 <%= event.localizacao %></small>
                    <% end %>
                  </p>
                </div>
              </div>
            <% end %>
          <% else %>
            <!-- Estado Inicial: Apenas Criado -->
            <div class="timeline-item active">
              <div class="timeline-icon">✓</div>
              <div class="timeline-content">
                <div class="timeline-header">
                  <p class="timeline-step">Pedido Criado</p>
                  <span class="timeline-time"><%= @package.created_at.strftime("%d/%m %H:%M") %></span>
                </div>
                <p class="timeline-desc">Informações de envio registradas no sistema.</p>
              </div>
            </div>
          <% end %>
        </div>
      </div>

    </div>

  </div>
</div>

<!-- Scripts e Estilos do Leaflet -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>

<script>
document.addEventListener("DOMContentLoaded", function() {
  const address = <%= @package.endereco.to_json.html_safe %>;
  const packageId = <%= @package.id %>;
  
  // 1. Inicializa o mapa com foco provisório na Paulista (CD)
  const originCoords = [-23.5615, -46.656]; // Centro de Distribuição Padrão
  const map = L.map('map').setView(originCoords, 13);
  
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    maxZoom: 19,
    attribution: '© OpenStreetMap contributors'
  }).addTo(map);

  let routeCoordinates = [];
  let truckMarker = null;
  let simInterval = null;
  let currentStep = 0;
  
  // Triggers para disparar eventos durante o trajeto
  let triggers = {
    coletado: false,
    em_transito: false,
    proximo: false,
    entregue: false
  };

  // 2. Geocodificar endereço do cliente usando Nominatim público
  const geocodeUrl = `https://nominatim.openstreetmap.org/search?format=json&limit=1&q=${encodeURIComponent(address)}`;
  
  fetch(geocodeUrl)
    .then(res => res.json())
    .then(data => {
      let destCoords;
      if (data && data.length > 0) {
        destCoords = [parseFloat(data[0].lat), parseFloat(data[0].lon)];
      } else {
        // Fallback realista próximo a SP
        destCoords = [-23.5855, -46.6754];
      }
      initializeMapAndRoute(originCoords, destCoords);
    })
    .catch(err => {
      console.warn("Nominatim error, using fallback location", err);
      initializeMapAndRoute(originCoords, [-23.5855, -46.6754]);
    });

  function initializeMapAndRoute(origin, dest) {
    // Adiciona os Marcadores Iniciais
    L.marker(origin).addTo(map).bindPopup("<b>Centro de Distribuição (CD)</b>").openPopup();
    L.marker(dest).addTo(map).bindPopup("<b>Destino do Pacote</b>");
    
    // Ajusta o zoom
    const bounds = L.latLngBounds([origin, dest]);
    map.fitBounds(bounds, { padding: [40, 40] });

    // 3. Obter rota via OSRM pública
    const osrmUrl = `https://router.project-osrm.org/route/v1/driving/${origin[1]},${origin[0]};${dest[1]},${dest[0]}?overview=full&geometries=geojson`;
    
    fetch(osrmUrl)
      .then(res => res.json())
      .then(routeData => {
        if (routeData.routes && routeData.routes.length > 0) {
          const route = routeData.routes[0];
          // Converte coordenadas da resposta [lon, lat] para [lat, lon] do Leaflet
          routeCoordinates = route.geometry.coordinates.map(coord => [coord[1], coord[0]]);
          
          // Desenha a linha da menor rota
          L.polyline(routeCoordinates, {
            color: '#1461ac',
            weight: 6,
            opacity: 0.8
          }).addTo(map);

          // Cria o marcador animado (Caminhão)
          const truckIcon = L.divIcon({
            className: 'custom-truck-icon',
            html: '<div style="font-size: 20px; line-height: 26px;">🚚</div>',
            iconSize: [26, 26],
            iconAnchor: [13, 13]
          });
          
          truckMarker = L.marker(origin, { icon: truckIcon }).addTo(map);

          // Libera botão de simulação
          const startBtn = document.getElementById('btn-start-sim');
          if (startBtn) {
            startBtn.disabled = false;
            startBtn.addEventListener('click', startSimulation);
          }
          document.getElementById('sim-status').innerText = "Rota calculada! Pronto para simular.";
        } else {
          document.getElementById('sim-status').innerHTML = "<span style='color:red;'>Erro ao calcular rota</span>";
        }
      })
      .catch(err => {
        console.error("OSRM Error:", err);
        document.getElementById('sim-status').innerHTML = "<span style='color:red;'>Erro de rota (OSRM indisponível)</span>";
      });
  }

  function startSimulation() {
    const startBtn = document.getElementById('btn-start-sim');
    startBtn.disabled = true;
    
    const speedSelect = document.getElementById('sim-speed');
    const speed = parseInt(speedSelect.value) || 400;
    
    currentStep = 0;
    triggers = { coletado: false, em_transito: false, proximo: false, entregue: false };
    
    document.getElementById('sim-status').innerHTML = "Simulação iniciada! 🚀";

    // Cancela intervalo anterior se houver
    if (simInterval) clearInterval(simInterval);
    
    // Inicia a animação passo a passo
    simInterval = setInterval(animateStep, speed);
  }

  function animateStep() {
    if (currentStep >= routeCoordinates.length) {
      clearInterval(simInterval);
      document.getElementById('sim-status').innerHTML = "Entrega finalizada com sucesso! ✅";
      return;
    }

    const currentCoords = routeCoordinates[currentStep];
    truckMarker.setLatLng(currentCoords);
    map.panTo(currentCoords);

    // Progresso percentual
    const progress = currentStep / (routeCoordinates.length - 1);

    // Gatilhos de eventos
    if (progress === 0 && !triggers.coletado) {
      triggers.coletado = true;
      sendEvent("Coletado", "Mercadoria coletada no CD de Origem e carregada no veículo de transporte.", "Centro de Distribuição");
    } else if (progress >= 0.3 && progress < 0.7 && !triggers.em_transito) {
      triggers.em_transito = true;
      sendEvent("Em Trânsito", "Veículo de entrega em deslocamento pela via expressa.", "Vias principais");
    } else if (progress >= 0.75 && progress < 0.95 && !triggers.proximo) {
      triggers.proximo = true;
      sendEvent("Saiu para Entrega", "O entregador está na vizinhança aproximando-se do destino.", "Vias locais");
    } else if (progress >= 0.98 && !triggers.entregue) {
      triggers.entregue = true;
      sendEvent("Entregue", "Entrega realizada com sucesso. Pacote recebido pelo destinatário.", address);
    }

    // Avança etapas na animação. Para rotas muito longas, saltamos coordenadas para acelerar a apresentação.
    const skip = Math.max(1, Math.floor(routeCoordinates.length / 40));
    currentStep += skip;
    if (currentStep > routeCoordinates.length - 1 && currentStep - skip < routeCoordinates.length - 1) {
      currentStep = routeCoordinates.length - 1; // Garante o último ponto
    }
  }

  function sendEvent(status, descricao, localizacao) {
    const token = document.querySelector('meta[name="csrf-token"]').getAttribute('content');
    
    document.getElementById('sim-status').innerHTML = `Enviando evento: <strong>${status}</strong>...`;

    fetch(`/packages/${packageId}/tracking_events`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': token
      },
      body: JSON.stringify({
        tracking_event: {
          status: status,
          descricao: descricao,
          localizacao: localizacao
        }
      })
    })
    .then(res => res.json())
    .then(data => {
      if (data.success) {
        document.getElementById('sim-status').innerHTML = `Evento <strong>${status}</strong> registrado no Banco!`;
        appendEventToTimeline(data.event);
        updatePackageStatusUI(status);
      }
    })
    .catch(err => {
      console.error("Erro ao enviar evento:", err);
    });
  }

  function appendEventToTimeline(event) {
    const container = document.getElementById('timeline-container');
    if (!container) return;

    // Remove placeholder inicial se for o único
    const placeholder = container.querySelector('.timeline-item:not(.active)');
    if (placeholder) placeholder.remove();

    const time = new Date(event.created_at);
    const timeStr = time.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });

    const item = document.createElement('div');
    item.className = 'timeline-item active';
    item.innerHTML = `
      <div class="timeline-icon">✓</div>
      <div class="timeline-content">
        <div class="timeline-header">
          <p class="timeline-step">${event.status}</p>
          <span class="timeline-time">${timeStr}</span>
        </div>
        <p class="timeline-desc">
          ${event.descricao}
          ${event.localizacao ? '<br/><small style="color: var(--color-blue);">📍 ' + event.localizacao + '</small>' : ''}
        </p>
      </div>
    `;

    const track = container.querySelector('.timeline-track');
    if (track && track.nextSibling) {
      container.insertBefore(item, track.nextSibling);
    } else {
      container.appendChild(item);
    }
  }

  function updatePackageStatusUI(status) {
    const statusText = document.querySelector('.status-text');
    const statusDot = document.querySelector('.status-dot');
    
    if (statusText) statusText.innerText = status;
    
    if (statusDot) {
      statusDot.className = 'status-dot';
      const clean = status.toLowerCase();
      if (clean.includes('pendente') || clean.includes('criado')) {
        statusDot.classList.add('pendente');
      } else if (clean.includes('rota') || clean.includes('trânsito') || clean.includes('saiu')) {
        statusDot.classList.add('rota');
      } else if (clean.includes('entregue')) {
        statusDot.classList.add('entregue');
      } else {
        statusDot.classList.add('default');
      }
    }
  }
});
</script>
