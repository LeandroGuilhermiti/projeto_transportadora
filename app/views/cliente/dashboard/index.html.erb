<div class="page-header">
  <h2>Minhas Entregas</h2>
  <p>Acompanhe todas as suas remessas e o histórico de eventos.</p>
</div>

<!-- KPI Cards -->
<div class="kpi-row">
  <div class="kpi-card">
    <span class="kpi-watermark">📦</span>
    <p class="kpi-label">Total de Entregas</p>
    <div class="kpi-value-row">
      <h2><%= @entregas.count > 0 ? sprintf("%02d", @entregas.count) : "00" %></h2>
      <span class="kpi-badge"><%= @entregas.count > 0 ? "registradas" : "Nenhuma" %></span>
    </div>
  </div>

  <div class="kpi-card">
    <span class="kpi-watermark">🚚</span>
    <p class="kpi-label">Em Trânsito</p>
    <div class="kpi-value-row">
      <h2><%= @total_em_transito > 0 ? sprintf("%02d", @total_em_transito) : "00" %></h2>
      <span class="kpi-badge muted">Em andamento</span>
    </div>
  </div>

  <div class="kpi-card">
    <span class="kpi-watermark">📍</span>
    <p class="kpi-label">Destinos</p>
    <div class="kpi-value-row">
      <h2><%= sprintf("%02d", @principais_rotas) %></h2>
      <span class="kpi-badge muted">Rotas ativas</span>
    </div>
  </div>
</div>

<!-- Tabela de Entregas -->
<div class="entregas-section">
  <table class="entregas-table">
    <thead>
      <tr>
        <th>Código</th>
        <th>Destinatário</th>
        <th>Destino</th>
        <th>Status</th>
        <th>Ação</th>
      </tr>
    </thead>
    <tbody>
      <% if @entregas.any? %>
        <% @entregas.each do |entrega| %>
          <tr>
            <td>
              <span class="tracking-code"><%= entrega.codigo_rastreio %></span>
            </td>
            <td>
              <div class="recipient-cell">
                <div class="recipient-avatar">
                  <%= entrega.destinatario.to_s.gsub(/[^A-Za-z ]/, '').split.map(&:first).first(2).join.upcase %>
                </div>
                <span class="recipient-name"><%= entrega.destinatario %></span>
              </div>
            </td>
            <td>
              <span class="destination-text"><%= entrega.regiao || "Não informado" %></span>
            </td>
            <td>
              <%
                status_class = case entrega.status&.downcase
                  when 'em_transito', 'em rota', 'em_rota' then 'status-em-transito'
                  when 'entregue'                           then 'status-entregue'
                  when 'atrasado'                           then 'status-atrasado'
                  when 'pendente'                           then 'status-pendente'
                  else                                          'status-processando'
                end
              %>
              <%
                status_label = case entrega.status&.downcase
                  when 'em_transito', 'em rota', 'em_rota' then 'Em Trânsito'
                  when 'entregue'                           then 'Entregue ✓'
                  when 'atrasado'                           then 'Atrasado'
                  when 'pendente'                           then 'Pendente'
                  else                                          entrega.status || 'Processando'
                end
              %>
              <span class="status-pill <%= status_class %>">
                <span class="dot"></span>
                <%= status_label %>
              </span>
            </td>
            <td>
              <%= link_to cliente_entrega_path(entrega), class: "btn-map-action", title: "Ver rastreamento e histórico", data: { turbo: false } do %>
                🗺️
              <% end %>
            </td>
          </tr>
        <% end %>
      <% else %>
        <tr>
          <td colspan="5">
            <div class="empty-state">
              <div class="empty-icon">📭</div>
              <p>Nenhuma entrega cadastrada ainda.</p>
              <%= link_to "Criar Nova Entrega", new_cliente_entrega_path, class: "btn-map-action", style: "display:inline-block; margin-top:12px; padding: 10px 20px;", data: { turbo: false } %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<style>
  .status-pendente { background: #fef9c3; color: #854d0e; }
  .status-pendente .dot { background: #ca8a04; }
</style>
