<% content_for :title, "Gestão de Veículos" %>

<div class="vehicles-wrapper">
  
  <!-- Header Section -->
  <div class="vehicles-header">
    <div>
      <h2>Gestão de Veículos</h2>
      <p>Gerenciamento completo do inventário de ativos e frota operacional.</p>
    </div>
    <%= link_to new_vehicle_path, class: "btn-add-vehicle" do %>
      <span style="font-size: 1.2rem;">+</span> Adicionar Veículo
    <% end %>
  </div>

  <!-- Stats Grid -->
  <div class="stats-grid">
    <div class="stat-card">
      <span class="stat-bg-icon">📦</span>
      <div class="stat-header">
        <span class="icon">📦</span>
        <h3>Total de Ativos</h3>
      </div>
      <p class="stat-value"><%= @total_vehicles %></p>
    </div>
    
    <div class="stat-card success">
      <span class="stat-bg-icon" style="color: #2ecc71;">✓</span>
      <div class="stat-header">
        <span class="icon">✓</span>
        <h3>Operacionais</h3>
      </div>
      <p class="stat-value"><%= @operacionais %></p>
    </div>
    
    <div class="stat-card warning">
      <span class="stat-bg-icon" style="color: var(--color-gold);">🔧</span>
      <div class="stat-header">
        <span class="icon">🔧</span>
        <h3>Em Manutenção</h3>
      </div>
      <p class="stat-value"><%= @manutencao %></p>
    </div>
    
    <div class="stat-card danger">
      <span class="stat-bg-icon" style="color: #e74c3c;">⚠</span>
      <div class="stat-header">
        <span class="icon">⚠</span>
        <h3>Indisponíveis</h3>
      </div>
      <p class="stat-value"><%= @indisponiveis %></p>
    </div>
  </div>

  <!-- Filter Tabs (Mock) -->
  <div class="filter-tabs">
    <button class="filter-tab active">Todos</button>
    <button class="filter-tab">Caminhões</button>
    <button class="filter-tab">Vans</button>
    <button class="filter-tab">Motos</button>
  </div>

  <!-- Vehicle Grid -->
  <div class="vehicle-grid">
    <% @vehicles.each do |vehicle| %>
      <div class="vehicle-card" id="<%= dom_id vehicle %>">
        
        <div class="vehicle-img-container">
          <!-- Placeholder dinâmico de imagem baseado na placa (hash simulado para gerar cores/ícones) -->
          <div style="width: 100%; height: 100%; background: linear-gradient(135deg, #e2e8f0, #cbd5e1); display: flex; align-items: center; justify-content: center; font-size: 4rem; color: #94a3b8;">
            🚐
          </div>
          <div class="vehicle-status-badge">
            <div class="status-dot-sm ok"></div>
            <span>Operacional</span>
          </div>
        </div>
        
        <div class="vehicle-card-body">
          <div class="vehicle-header-row">
            <div>
              <h4 class="vehicle-model"><%= vehicle.modelo %></h4>
              <p class="vehicle-type">Capacidade: <%= vehicle.capacidade.present? ? "#{vehicle.capacidade} kg" : "N/I" %></p>
            </div>
            <span class="vehicle-plate"><%= vehicle.placa %></span>
          </div>
          
          <div class="vehicle-metrics">
            <div class="metric-box">
              <span class="metric-label">Kilometragem</span>
              <span class="metric-value">
                <span style="color: var(--color-blue); font-size: 1rem;">⚡</span>
                <%= rand(10..150) %>.000 km
              </span>
            </div>
            <div class="metric-box">
              <span class="metric-label">Próx. Manut.</span>
              <span class="metric-value">
                <span style="color: var(--color-gold); font-size: 1rem;">🔧</span>
                <%= rand(1..9) %>.<%= rand(100..999) %> km
              </span>
            </div>
          </div>
          
          <div class="vehicle-actions">
            <%= link_to "Ver Histórico", vehicle, class: "btn-vehicle-action primary-action" %>
            <%= link_to "✎", edit_vehicle_path(vehicle), class: "btn-vehicle-action icon-action" %>
            <%= link_to "🗑", vehicle, data: { turbo_method: :delete, turbo_confirm: "Tem certeza que deseja apagar o veículo #{vehicle.placa}?" }, class: "btn-vehicle-action icon-action danger-action" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

</div>
